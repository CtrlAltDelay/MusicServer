# ─────────────────────────────────────────────────────────────────────────────
# .env — copy to .env and fill in real values before running docker compose
# NEVER commit this file to git
# ─────────────────────────────────────────────────────────────────────────────

# Your user/group IDs on the host (run: id -u && id -g)
PUID=1000
PGID=1000
TZ=America/New_York

# ── Last.fm ───────────────────────────────────────────────────────────────────
# Get API key from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_SECRET=your_lastfm_secret_here
LASTFM_USERNAME=your_lastfm_username_here

# ── Lidarr ────────────────────────────────────────────────────────────────────
# Get from Lidarr UI: Settings → General → Security → API Key
# (Start Lidarr first, then copy the key here and restart)
LIDARR_API_KEY=your_lidarr_api_key_here

# ── Navidrome ─────────────────────────────────────────────────────────────────
# Password for the Navidrome admin account (created on first run)
# Also used by the Lidarr hook script to trigger rescans
NAVIDROME_ADMIN_USER=admin
NAVIDROME_ADMIN_PASS=change_me_to_a_strong_password
