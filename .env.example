# ─────────────────────────────────────────────────────────────────────────────
# .env — copy to .env and fill in real values before running docker compose
# NEVER commit this file to git
# ─────────────────────────────────────────────────────────────────────────────

# Your user/group IDs on the host (run: id -u && id -g)
PUID=1000
PGID=1000
TZ=America/New_York

# ── Soulseek (slskd) ─────────────────────────────────────────────────────────
# No prior registration needed — slskd registers the account on the Soulseek
# network automatically the first time it connects with these credentials.
# Just pick a username/password (usernames must be unique on the network).
SOULSEEK_USERNAME=your_soulseek_username_here
SOULSEEK_PASSWORD=your_soulseek_password_here
# API key for slskd — Soularr uses this to talk to slskd.
# Pick any random string 16–255 chars (e.g.: openssl rand -hex 24)
SLSKD_API_KEY=CHANGE_ME_RANDOM_STRING_HERE

# ── ListenBrainz ─────────────────────────────────────────────────────────────
# Username at https://listenbrainz.org (same as you use to log in)
LISTENBRAINZ_USERNAME=your_listenbrainz_username_here
# User token from https://listenbrainz.org/settings/ — optional for discovery
# stats reads, but recommended for higher API rate limits. Required for Navidrome
# to submit listens to ListenBrainz when ND_LISTENBRAINZ_ENABLED is true.
LISTENBRAINZ_TOKEN=

# ── Discovery bridge web UI (optional) ───────────────────────────────────────
# Host port published to the Flask UI inside the container (container listens on 8765).
DISCOVERY_HOST_GUI_PORT=8765
# mood (tiered Daily Jams / recent / monthly) | most_listened | loved | both
DISCOVERY_SEED_MODE=mood
# Minimum Labs similarity (0–1) for a similar artist to count as a candidate
MIN_SIMILARITY=0.7
# Time window for most_listened stats (e.g. quarterly, year, all_time)
LISTENBRAINZ_STATS_RANGE=quarterly
# Required by MusicBrainz API policy for metadata quality checks (include contact URL or email)
# MUSICBRAINZ_USER_AGENT=music-discovery-bridge/1.0 ( you@example.com )
# Optional mood tuning:
# MOOD_MIN_SEED_MBIDS=5
# RECENT_LISTENS_DAYS=7
# DAILY_JAMS_TITLE_SUBSTRING=daily jam
# TIER1_SIMILARITY_MULTIPLIER=1.5
# Optional token; if set, every path except / requires ?token=... or the
# X-Discovery-Token header (open the UI as /?token=... so API calls match).
DISCOVERY_GUI_TOKEN=

# ── Lidarr ────────────────────────────────────────────────────────────────────
# Get from Lidarr UI: Settings → General → Security → API Key
# (Start Lidarr first, then copy the key here and restart)
LIDARR_API_KEY=your_lidarr_api_key_here

# ── Navidrome ─────────────────────────────────────────────────────────────────
# Password for the Navidrome admin account (created on first run)
# Also used by the Lidarr hook script to trigger rescans
NAVIDROME_ADMIN_USER=admin
NAVIDROME_ADMIN_PASS=change_me_to_a_strong_password
